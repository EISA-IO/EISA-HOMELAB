# =============================================================================
# EISA HOMELAB ULTIMATE — environment template
# Copy this file to `.env`, then run RUN.bat to launch the wizard.
# The wizard will fill in any blanks interactively, generate strong secrets
# where required, and write the final values back here.
# =============================================================================

# Host UID/GID (Windows users: leave 1000/1000 — only used inside containers).
PUID=1000
PGID=1000

# Container default user (only used by some images).
USER=admin
PASS=__CHANGE_ME_STRONG_PASSWORD__

# Where bind-mount config volumes live on disk (relative to compose file is OK).
PERSISTENT_STORAGE=./persistent-storage

# Public domain used by Caddy + Authelia. Leave blank for LOCAL-ONLY mode
# (no Cloudflare tunnel; everything reachable only on the LAN by host:port).
DOMAIN=

# =============================================================================
# CLOUDFLARED — ONLINE / TUNNEL MODE ONLY
# Generate at https://one.dash.cloudflare.com/ → Networks → Tunnels → Create
# Leave blank to disable the cloudflared container (local-only mode).
# =============================================================================
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# LINKWARDEN (only if you re-enable the linkwarden service in compose)
# =============================================================================
LINKWARDEN_DB_PASSWORD=__CHANGE_ME__
LINKWARDEN_DB_USERNAME=admin
LINKWARDEN_DB_DATABASE_NAME=linkwardenDB
NEXTAUTH_SECRET=__GENERATE_32_BYTE_BASE64__

# =============================================================================
# IMMICH — only if you re-enable the immich services in compose
# =============================================================================
DB_PASSWORD=__CHANGE_ME__
DB_USERNAME=admin
DB_DATABASE_NAME=adminDB
IMMICH_VERSION=release
PERSONAL_ALL_LOCATION=immich
PERSONAL_REDIS_LOCATION=./persistent-storage/do-not-delete/immich-personal/redis
PERSONAL_DB_DATA_LOCATION=./persistent-storage/do-not-delete/immich-personal/postgres
PERSONAL_ML_CACHE_LOCATION=./persistent-storage/do-not-delete/immich-personal/ml-cache

# =============================================================================
# KAVITA — only if you re-enable the kavita service in compose
# =============================================================================
PERSONAL_KAVITA_DB_DATA_LOCATION=./persistent-storage/kavita-personal

# =============================================================================
# MEDIA / FILE BROWSER LOCATIONS
# STORAGE_DISK is the drive root (Windows: F:, Linux: /mnt/storage).
# All other *_LOCATION values are paths *relative to* STORAGE_DISK.
# =============================================================================
STORAGE_DISK=F:
IMMICH_LOCATION=media/immich
BOOKS_LOCATION=media/books
AUDIO_LOCATION=media/audio
VIDEOS_LOCATION=media/videos
PICTURES_LOCATION=media/pictures
GAMES_LOCATION=media/games
DOCUMENTS_LOCATION=media/documents
DOWNLOADS_LOCATION=downloads
SOFTWARE_LOCATION=software
PLEX_LOCATION=plex

# =============================================================================
# N8N — workflow automation
# Generate strong values; the wizard does this for you on first run.
# =============================================================================
POSTGRES_USER=root
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=n8n
N8N_ENCRYPTION_KEY=__GENERATE_32_BYTE_HEX__
N8N_USER_MANAGEMENT_JWT_SECRET=__GENERATE_32_BYTE_HEX__

# Mac users running OLLAMA on the host (not in compose) — see n8n self-hosted-ai-starter-kit docs.
OLLAMA_HOST=host.docker.internal:11434

# =============================================================================
# HERMES AGENT (gateway requires non-empty bearer; workspace fail-closes
# on non-loopback bind without a password).
# =============================================================================
HERMES_API_KEY=__GENERATE_64_BYTE_HEX__
HERMES_DASHBOARD_TOKEN=__GENERATE_64_BYTE_HEX__
HERMES_DEFAULT_MODEL=carstenuhlig/omnicoder-2-9b:q4_k_m
HERMES_DEFAULT_CONTEXT=65536
HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_PORT=9119
HERMES_WORKSPACE_PORT=3000
HERMES_WORKSPACE_PASSWORD=__CHANGE_ME_STRONG_PASSWORD__
