###############################################################
#                   Authelia configuration                    #
#                                                             #
#  ${DOMAIN} is substituted at startup by setup.ps1.          #
#  jwt_secret + storage.encryption_key are generated by the   #
#  wizard and written into this file on first run.            #
###############################################################
theme: dark

server:
  asset_path: /assets
  endpoints:
    authz:
      forward-auth:
        implementation: ForwardAuth

log:
  level: info

totp:
  issuer: ${DOMAIN}

identity_validation:
  reset_password:
    jwt_secret: __AUTHELIA_JWT_SECRET__

authentication_backend:
  file:
    path: /config/users_database.yml

access_control:
  default_policy: deny
  rules:

###############################################################
#                      BYPASS (no auth)                       #
###############################################################
    - domain: auth.${DOMAIN}
      policy: bypass
    - domain: c.${DOMAIN}
      policy: bypass

###############################################################
#                         TOOLS                               #
###############################################################
    - domain: tool.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
    - domain: tor.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
    - domain: search.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins

###############################################################
#                      INFRASTRUCTURE                         #
###############################################################
    - domain: portainer.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
    - domain: hub.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins

###############################################################
#                         AI IMAGES                           #
###############################################################
    - domain: flux.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
    - domain: pony.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins

###############################################################
#                         AI AUDIO                            #
###############################################################
    - domain: voice.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins

###############################################################
#                          AI AGENTS/CHAT                     #
###############################################################
    - domain: n8n.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
    - domain: hermes.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
    - domain: chat.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
###############################################################
#                          MEDIA                              #
###############################################################
    - domain: music.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
    - domain: file.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
    - domain: movie.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins

###############################################################
#                          STASH                              #
###############################################################
    - domain: manga.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins
    - domain: cookies.${DOMAIN}
      policy: one_factor
      subject:
        - group:admins

session:
  expiration: 6h
  inactivity: 5h
  remember_me_duration: 2M
  cookies:
    - domain: ${DOMAIN}
      authelia_url: https://auth.${DOMAIN}
      default_redirection_url: https://hub.${DOMAIN}

regulation:
  max_retries: 3
  find_time: '2m'
  ban_time: '30m'

storage:
  encryption_key: "__AUTHELIA_STORAGE_ENCRYPTION_KEY__"
  local:
    path: /config/db.sqlite3

notifier:
  filesystem:
    filename: /config/notification.txt
