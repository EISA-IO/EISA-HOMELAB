# =============================================================================
# Caddy reverse proxy — EISA HOMELAB ULTIMATE
# Layout & routing mirror authelia/configuration.yml. Keep them in sync.
#
# ${DOMAIN} is substituted at startup by setup.ps1 (PowerShell template render).
# Set DOMAIN= empty for local-only mode and Caddy will not be reached from
# the internet; you'll hit services directly by host:port instead.
# =============================================================================

{
	email     admin@${DOMAIN}
	auto_https off
	http_port 80
}

# -----------------------------------------------------------------------------
# Forward-auth snippet — every protected route imports this.
# -----------------------------------------------------------------------------
(forward_auth) {
	forward_auth Authelia:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Email Remote-Name
		header_up X-Forwarded-Proto https
	}
}

# =============================================================================
# BYPASS — no Authelia (matches: bypass rules in configuration.yml)
# =============================================================================

http://auth.${DOMAIN} {
	reverse_proxy Authelia:9091
}

http://c.${DOMAIN} {
	reverse_proxy immich-server:2283
}

# =============================================================================
# TOOLS
# =============================================================================

http://tool.${DOMAIN} {
	import forward_auth
	reverse_proxy host.docker.internal:8890
}

# Tor / KasmVNC auto-login snippet — used by both the public tor.${DOMAIN}
# vhost (behind Authelia) and the local-only http://tor.localhost vhost.
#   1. Bare / 302s to /vnc.html?...&autoconnect=true so kasm's JS
#      auto-connects to the desktop without any clicks.
#   2. header_up Authorization injects HTTP basic-auth on every proxied
#      request, which is what gates /vnc.html. Without this the browser
#      would still get a kasm login prompt.
# The wizard substitutes ${TOR_VNC_PW} + ${TOR_BASIC_AUTH} at render time.
(tor_autologin) {
	@root path /
	redir @root /vnc.html?username=kasm_user&password=${TOR_VNC_PW}&autoconnect=true&resize=remote 302
	reverse_proxy https://host.docker.internal:6901 {
		transport http {
			tls_insecure_skip_verify
		}
		header_up Authorization "Basic ${TOR_BASIC_AUTH}"
	}
}

http://tor.${DOMAIN} {
	import forward_auth
	import tor_autologin
}

# Local-only zero-click bookmark. *.localhost resolves to 127.0.0.1 on
# Windows 10+, macOS, and Linux without any hosts-file edits, so opening
# http://tor.localhost/ in any browser on this machine lands directly in
# the Tor desktop with no Authelia, no kasm prompt, no form.
http://tor.localhost {
	import tor_autologin
}

http://search.${DOMAIN} {
	import forward_auth
	reverse_proxy searxng:8080
}

