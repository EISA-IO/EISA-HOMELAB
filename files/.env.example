# =============================================================================
# EISA HOMELAB ULTIMATE - environment template
# Copy this file to `.env`, then run WINDOWS-HOMELAB-MANAGER.BAT (or
# MAC-HOMELAB-MANAGER.COMMAND on macOS) and pick [1] First-Run Setup.
# The wizard will fill in any blanks interactively, generate strong secrets
# where required, and write the final values back here.
# =============================================================================

# Host UID/GID (Windows users: leave 1000/1000 - only used inside containers).
PUID=1000
PGID=1000

# Timezone used by services that show times (Heimdall, Navidrome, Jellyfin).
# Use any tzdata zone, e.g. "America/New_York", "Europe/Berlin", "Asia/Tokyo".
# Default is Asia/Riyadh.
TZ=Asia/Riyadh

# Container default user (only used by some images).
USER=admin
PASS=__CHANGE_ME_STRONG_PASSWORD__

# Where bind-mount config volumes live on disk (relative to compose file is OK).
PERSISTENT_STORAGE=./persistent-storage

# Public domain used by Caddy + Authelia. Leave blank for LOCAL-ONLY mode
# (no Cloudflare tunnel; everything reachable only on the LAN by host:port).
DOMAIN=

# Base domain for Heimdall start-page tiles. The wizard prompts for this
# during first-run setup. If set, tiles become https://chat.<domain>,
# https://movie.<domain>, etc. If blank, tiles point at http://localhost:PORT
# for local-only access. Rewrite runs once when placeholder URLs are
# detected in app.sqlite; user customizations are never clobbered.
HEIMDALL_TILE_DOMAIN=

# =============================================================================
# CLOUDFLARED - ONLINE / TUNNEL MODE ONLY
# Generate at https://dash.cloudflare.com/ → Networks → Tunnels → Create
# Leave blank to disable the cloudflared container (local-only mode).
# =============================================================================
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# MEDIA FOLDERS - full paths on the host. The wizard prompts for these
# in plain language ("MOVIES FOLDER LOCATION", "TV SHOWS FOLDER LOCATION",
# etc.) and writes them here. Use forward slashes so docker compose is happy
# (the wizard normalises backslashes for you).
# =============================================================================
MOVIES_PATH=C:/MEDIA/Movies
TV_SHOWS_PATH=C:/MEDIA/TV-Shows
MUSIC_PATH=C:/MEDIA/Music
DOWNLOADS_PATH=C:/MEDIA/Downloads
PHOTOS_PATH=C:/MEDIA/Photos

# =============================================================================
# IMMICH - self-hosted photo + video library (web UI on http://localhost:2283)
# DB_PASSWORD is auto-generated by the wizard. DB_USERNAME/DATABASE_NAME stay
# simple - they only matter inside the immich-postgres container.
# IMMICH_VERSION pins the upstream image tag; 'release' tracks the latest stable.
# =============================================================================
DB_PASSWORD=__CHANGE_ME__
DB_USERNAME=immich
DB_DATABASE_NAME=immich
IMMICH_VERSION=v2.7.5

# =============================================================================
# LINKWARDEN (only if you re-enable the linkwarden service in compose)
# =============================================================================
LINKWARDEN_DB_PASSWORD=__CHANGE_ME__
LINKWARDEN_DB_USERNAME=admin
LINKWARDEN_DB_DATABASE_NAME=linkwardenDB
NEXTAUTH_SECRET=__GENERATE_32_BYTE_BASE64__

# =============================================================================
# N8N - workflow automation
# Generate strong values; the wizard does this for you on first run.
# =============================================================================
POSTGRES_USER=root
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=n8n
N8N_ENCRYPTION_KEY=__GENERATE_32_BYTE_HEX__
N8N_USER_MANAGEMENT_JWT_SECRET=__GENERATE_32_BYTE_HEX__

# Mac users running OLLAMA on the host (not in compose) - see n8n self-hosted-ai-starter-kit docs.
OLLAMA_HOST=host.docker.internal:11434

# =============================================================================
# TOR BROWSER (KasmVNC)
# Used both inside the container (as VNC_PW) and baked into the auto-login
# URL by Caddy so you never see the kasm login form. The kasm user is fixed
# at `kasm_user` upstream.
# =============================================================================
TOR_VNC_PW=__CHANGE_ME_STRONG_PASSWORD__

# =============================================================================
# AUTHELIA ADMIN USER
# Auto-populated by setup.ps1 the first time it runs: it generates a strong
# random password, derives the argon2 hash, writes the hash into
# persistent-storage/do-not-delete/authelia/users_database.yml, and writes the cleartext
# password here so you can recover it. The Authelia username is `admin`.
# =============================================================================
AUTHELIA_ADMIN_PASSWORD=

# =============================================================================
# REQUEST + DOWNLOAD STACK (Seerr / Sonarr / Radarr / Prowlarr / qBittorrent)
# API keys are pre-generated by setup.ps1 on first run and baked into each
# app's config.xml BEFORE the container starts, so the configurator can wire
# everything together (download client, indexers, 1080p quality profile)
# without any manual setup. Regenerate by clearing these values and
# re-running the wizard with -Reconfigure.
# qBittorrent ships with admin/adminadmin via a known PBKDF2 hash plus a
# subnet whitelist that lets containers on the caddy network and 127.0.0.1
# bypass auth entirely (so the configurator works without creds).
# =============================================================================
SONARR_API_KEY=__GENERATE_32_BYTE_HEX__
RADARR_API_KEY=__GENERATE_32_BYTE_HEX__
PROWLARR_API_KEY=__GENERATE_32_BYTE_HEX__
SEERR_API_KEY=__GENERATE_32_BYTE_HEX__
# qBittorrent v5 requires a WebUI password >= 6 characters, so it's the one
# exception to the admin/admin default. adminadmin is the legacy v4 default
# and the value all *arr apps know about.
QBITTORRENT_WEBUI_USERNAME=admin
QBITTORRENT_WEBUI_PASSWORD=adminadmin

# Jellyfin + Seerr share the same admin credentials: Seerr can only create
# its first admin user by signing in with a Jellyfin admin, so the wizard
# auto-runs Jellyfin's first-run wizard with these values, then re-uses them
# to bootstrap Seerr. If Jellyfin is already set up, only the username
# matters (Seerr won't be auto-bootstrapped - finish in the UI).
JELLYFIN_ADMIN_USERNAME=admin
JELLYFIN_ADMIN_PASSWORD=admin
# Long-lived Jellyfin API key, created by the wizard after first-run for use
# by external clients (Seerr, external scripts, etc.).
JELLYFIN_API_KEY=

# =============================================================================
# HERMES AGENT / WORKSPACE
# A single shared bearer token gates BOTH the agent gateway (port 8642) and
# the dashboard (port 9119). hermes-workspace authenticates with the same
# token. setup.ps1 generates a strong random value on first run.
# =============================================================================
HERMES_API_KEY=__GENERATE_32_BYTE_HEX__
