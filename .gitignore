# =============================================================================
# Secrets - NEVER commit
# =============================================================================
files/.env
files/.env.local
files/.env.*.local
files/.wizard-state.json

# Per-user runtime state written by the LLM manager (remembers last-chosen ctx).
files/context_size.cfg

# Rendered configs (templates with .tmpl are committed; resolved files are not).
files/persistent-storage/do-not-delete/caddy/Caddyfile
files/persistent-storage/do-not-delete/authelia/configuration.yml
files/persistent-storage/do-not-delete/searxng/settings.yml
# Hermes Agent config.yaml is auto-rendered by Configure-HermesAgent
# (locks the agent to in-stack Ollama). The directory is bind-mounted
# so it must exist; the file inside is regenerated on every run.
files/persistent-storage/do-not-delete/hermes-agent/

# Real users database (only the .example template is committed).
files/persistent-storage/do-not-delete/authelia/users_database.yml

# =============================================================================
# Runtime data - bind-mounts that fill up at runtime
# =============================================================================
files/persistent-storage/do-not-delete/caddy/caddy_data/
files/persistent-storage/do-not-delete/caddy/caddy_config/
files/persistent-storage/do-not-delete/caddy/site/
files/persistent-storage/do-not-delete/caddy/Caddyfile.bak.*

files/persistent-storage/do-not-delete/authelia/db.sqlite3
files/persistent-storage/do-not-delete/authelia/notification.txt
files/persistent-storage/do-not-delete/authelia/assets/
files/persistent-storage/do-not-delete/authelia/overrides/

files/persistent-storage/jellyfin/
files/persistent-storage/navidrome/
files/persistent-storage/portainer/
files/persistent-storage/n8n/
files/persistent-storage/immich/
files/persistent-storage/do-not-delete/heimdall/**
# ...but ship the Heimdall dashboard seed (DB + uploaded icons + backgrounds)
# so fresh installs get the pre-built tile layout. Logs / certs / nginx +
# php runtime configs / sqlite auto-backups / heimdall's internal .env stay
# ignored. The /** above + ancestor un-ignores is the only pattern git's
# gitignore parser handles correctly here.
!files/persistent-storage/do-not-delete/heimdall/
!files/persistent-storage/do-not-delete/heimdall/config/
!files/persistent-storage/do-not-delete/heimdall/config/www/
!files/persistent-storage/do-not-delete/heimdall/config/www/app.sqlite
!files/persistent-storage/do-not-delete/heimdall/config/www/backgrounds/
!files/persistent-storage/do-not-delete/heimdall/config/www/backgrounds/**
!files/persistent-storage/do-not-delete/heimdall/config/www/icons/
!files/persistent-storage/do-not-delete/heimdall/config/www/icons/**
# Re-ignore the sqlite auto-backups even though icons/backgrounds are un-ignored.
files/persistent-storage/do-not-delete/heimdall/config/www/app.sqlite.bak.*
files/persistent-storage/do-not-delete/filebrowser/filebrowser.db
files/persistent-storage/do-not-delete/filebrowser/storage/
files/persistent-storage/do-not-delete/tor/
# *arr stack - runtime DBs, logs, sqlite, generated XML configs all live here.
files/persistent-storage/do-not-delete/sonarr/
files/persistent-storage/do-not-delete/radarr/
files/persistent-storage/do-not-delete/prowlarr/
files/persistent-storage/do-not-delete/qbittorrent/
files/persistent-storage/do-not-delete/seerr/

# SearXNG state files we don't want to ship.
files/persistent-storage/do-not-delete/searxng/*.new

# =============================================================================
# Editor / OS / tooling junk
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/
backups/
