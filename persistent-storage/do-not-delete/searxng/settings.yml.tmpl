# see https://docs.searxng.org/admin/settings/settings.html#settings-use-default-settings
use_default_settings: true

server:
  # Generated by RUN.bat on first run. Replace manually with a 64-char hex
  # string if you ever copy this template into place by hand.
  secret_key: "__SEARXNG_SECRET_KEY__"
  limiter: false
  image_proxy: true
  port: 8080
  bind_address: "0.0.0.0"

ui:
  static_use_hash: true

search:
  safe_search: 0
  autocomplete: ""
  default_lang: ""
  formats:
    - html
    - json

# Vane requires wolframalpha for math/unit-conversion queries; default is
# disabled. Override here without redeclaring the full default engine list.
engines:
  - name: wolframalpha
    disabled: false
